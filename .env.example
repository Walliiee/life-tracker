# Life Tracker – environment configuration
# Copy to .env and adjust values, then: export $(cat .env | xargs)

# Server port (default: 5001)
PORT=5001

# Enable Flask debug mode — never set to true in production (default: false)
DEBUG=false

# Bearer token for API auth — leave unset to disable auth (safe for localhost)
# API_TOKEN=change-me-to-a-strong-random-token

# Ollama model used for report generation (default: minimax-m2.7:cloud)
OLLAMA_MODEL=minimax-m2.7:cloud
